{
  "name": "{{ container_name | capitalize }} Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:Australia/Adelaide}",
      "CLAUDE_CODE_VERSION": "stable",
      "GIT_DELTA_VERSION": "0.18.2"
    }
  },
  "runArgs": [
{%- if enable_firewall %}
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
{%- endif %}
    "--env-file",
    "${localWorkspaceFolder}/devcontainer.env",
    "--sysctl",
    "net.ipv6.conf.all.disable_ipv6=1"
  ],
  "customizations": {
    "vscode": {
{%- set _exts = ['anthropic.claude-code', 'esbenp.prettier-vscode', 'eamodio.gitlens'] -%}
{%- if 'uv' in installed_tools %}{%- set _exts = _exts + ['ms-python.python', 'charliermarsh.ruff'] -%}{%- endif %}
{%- if 'java' in installed_tools %}{%- set _exts = _exts + ['vscjava.vscode-java-pack'] -%}{%- endif %}
{%- if 'rust' in installed_tools %}{%- set _exts = _exts + ['rust-lang.rust-analyzer'] -%}{%- endif %}
{%- if 'nextflow' in installed_tools %}{%- set _exts = _exts + ['nextflow.nextflow', 'editorconfig.editorconfig', 'gruntfuggly.todo-tree', 'redhat.vscode-yaml', 'mechatroner.rainbow-csv', 'oderwat.indent-rainbow'] -%}{%- endif %}
{%- if 'awscli' in installed_tools or 'aws-cdk' in installed_tools %}{%- set _exts = _exts + ['amazonwebservices.aws-toolkit-vscode'] -%}{%- endif %}
      "extensions": {{ _exts | unique | list | tojson }},
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {},
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "remoteUser": "claude",
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=claude-code-config-${devcontainerId},target=/home/claude/.claude,type=volume"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/claude/.claude"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postStartCommand": "/usr/local/bin/startup.sh",
  "waitFor": "postStartCommand"
}
