#!/usr/bin/env bash
# Root-phase installers. Invoked from the Dockerfile while USER=root.
set -euo pipefail
IFS=$'\n\t'

{% if 'java' in installed_tools %}
# ── Java 21 (Temurin) ─────────────────────────────────────────────────
wget -qO - https://packages.adoptium.net/artifactory/api/gpg/key/public \
  | gpg --dearmor -o /usr/share/keyrings/adoptium.gpg
echo "deb [signed-by=/usr/share/keyrings/adoptium.gpg] \
  https://packages.adoptium.net/artifactory/deb \
  $(awk -F= '/^VERSION_CODENAME/{print $2}' /etc/os-release) main" \
  > /etc/apt/sources.list.d/adoptium.list
apt-get update
apt-get install -y --no-install-recommends temurin-21-jdk
apt-get clean && rm -rf /var/lib/apt/lists/*
{% endif %}

{% if 'nextflow' in installed_tools %}
# ── Nextflow ──────────────────────────────────────────────────────────
NEXTFLOW_VERSION="${NEXTFLOW_VERSION:-25.10.4}"
wget -qO /usr/local/bin/nextflow \
  "https://github.com/nextflow-io/nextflow/releases/download/v${NEXTFLOW_VERSION}/nextflow-${NEXTFLOW_VERSION}-dist"
chmod +x /usr/local/bin/nextflow
{% endif %}

{% if 'awscli' in installed_tools %}
# ── AWS CLI v2 ────────────────────────────────────────────────────────
ARCH=$(uname -m)
case "$ARCH" in
  x86_64)  AWSCLI_ARCH=x86_64 ;;
  aarch64) AWSCLI_ARCH=aarch64 ;;
  *) echo "Unsupported arch for awscli: $ARCH" >&2; exit 1 ;;
esac
tmpdir=$(mktemp -d) && cd "$tmpdir"
curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-${AWSCLI_ARCH}.zip" -o awscliv2.zip
unzip -q awscliv2.zip
./aws/install
cd / && rm -rf "$tmpdir"
{% endif %}
